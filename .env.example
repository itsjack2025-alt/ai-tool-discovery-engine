# ===========================================
# AI Tool Discovery Engine v3.0 - Configuration
# Copy this file to .env and fill in your values
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB (Required - use MongoDB Atlas for production)
MONGODB_URI=mongodb://localhost:27017/ai_tool_discovery

# Redis (Optional - for BullMQ workers)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# GitHub API (optional - increases rate limits)
GITHUB_TOKEN=

# Product Hunt API (optional)
PRODUCTHUNT_API_KEY=
PRODUCTHUNT_API_SECRET=

# Crawler Settings
CRAWLER_CONCURRENCY=5
CRAWLER_DELAY_MS=2000
CRAWLER_MAX_PAGES=100
CRAWLER_USER_AGENT=AIToolDiscoveryBot/1.0

# Scheduler
DAILY_DISCOVERY_CRON=0 2 * * *
HOURLY_SIGNALS_CRON=0 * * * *

# Trend Settings
TREND_DECAY_FACTOR=0.95
MIN_TREND_SCORE=0.1
TOP_TRENDING_COUNT=50

# Logging
LOG_LEVEL=info
LOG_FILE=logs/discovery.log

# Admin
ADMIN_USERNAME=CallmeJack
ADMIN_EMAIL=admin@aitool.discovery
ADMIN_PASSWORD=Jack@2026

# Notifications (for business inquiries)
NOTIFICATION_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Deployment
SITE_URL=
DEPLOY_DOMAIN=
